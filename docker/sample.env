# Picstome stack — copy into Portainer: Stack → Advanced → Environment variables (or .env editor).
# Prerequisite on the Docker host: docker network create Network-Bridge
#
# Change passwords and APP_URL before production. MYSQL_DATABASE / MYSQL_USER / MYSQL_PASSWORD
# must match DB_DATABASE / DB_USERNAME / DB_PASSWORD.

# --- Container image & HTTP ---
PICSTOME_IMAGE=ghcr.io/honestlai/picstome:latest
PICSTOME_HTTP_PORT=8080

# --- MySQL (Picstome-MySQL service) ---
MYSQL_IMAGE=mysql:8.0
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=picstome
MYSQL_USER=picstome
MYSQL_PASSWORD=change-this-app-password

# --- Laravel database (must match MYSQL_* above) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=picstome
DB_USERNAME=picstome
DB_PASSWORD=change-this-app-password

# --- App core (leave APP_KEY empty to auto-generate on first boot) ---
APP_NAME=Picstome
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://photos.example.com
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# --- Session / queue / cache (database driver uses MySQL above) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

# --- Redis (not used by default stack; leave as-is or add a Redis service later) ---
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# --- Mail ---
MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=Picstome

# --- AWS / S3 (optional; Picstome config defaults disk to s3 for app logic — set for production uploads) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ORIGIN=

VITE_APP_NAME=Picstome

# --- Stripe (required for billing features) ---
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_LIVE_SECRET=
STRIPE_TEST_SECRET=
STRIPE_EN_PRICING_TABLE_ID=
STRIPE_ES_PRICING_TABLE_ID=
STRIPE_LIFETIME_PRICE_ID=

# --- Picstome ---
PICSTOME_ADMIN_EMAILS=admin@example.com
PICSTOME_PHOTO_CDN_DOMAIN=wsrv.nl
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=
SHORT_URL_DOMAIN=

HONEYBADGER_API_KEY=
HONEYBADGER_VERIFY_SSL=

ACUMBAMAIL_AUTH_TOKEN=
ACUMBAMAIL_LIST_ID=
ACUMBAMAIL_LIST_ID_ES=

# --- Container entrypoint ---
PICSTOME_AUTO_MIGRATE=1
PICSTOME_SEED_ON_FIRST_BOOT=0
